# Professional Playwright Framework Environment Configuration
# Copy this file to .env and update values according to your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Base URL for the application under test
BASE_URL=https://example.com

# Environment type (development, staging, production, testing)
ENVIRONMENT=staging

# Run browser in headless mode (true/false)
HEADLESS=false

# =============================================================================
# BROWSER CONFIGURATION
# =============================================================================

# Browser to use (chromium, firefox, webkit)
BROWSER_NAME=chromium

# Slow motion delay between actions (milliseconds)
BROWSER_SLOW_MO=100

# Default timeout for browser operations (milliseconds)
TIMEOUT=30000

# Browser window size (width,height)
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# Additional browser arguments
BROWSER_ARGS=["--disable-web-security", "--disable-features=VizDisplayCompositor"]

# Remote browser URL (for BrowserStack, Sauce Labs, etc.)
BROWSER_REMOTE_URL=

# =============================================================================
# TEST EXECUTION SETTINGS
# =============================================================================

# Number of parallel workers for test execution
PARALLEL_WORKERS=4

# Maximum retry attempts for failed tests
RETRY_MAX_ATTEMPTS=3

# Delay between retry attempts (seconds)
RETRY_DELAY=1.0

# Take screenshot on test failure (true/false)
SCREENSHOT_ON_FAILURE=true

# Record video on test failure (true/false)
VIDEO_ON_FAILURE=false

# Enable performance monitoring (true/false)
PERFORMANCE_MONITORING=true

# Enable accessibility checking (true/false)
ACCESSIBILITY_CHECKING=true

# Enable security scanning (true/false)
SECURITY_SCANNING=false

# =============================================================================
# REPORTING CONFIGURATION
# =============================================================================

# Reports directory
REPORTS_DIR=reports

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable structured logging (true/false)
STRUCTURED_LOGGING=true

# Log format for console output
LOG_FORMAT=%(asctime)s [%(levelname)8s] %(name)s: %(message)s

# Log format for file output
LOG_FILE_FORMAT=%(asctime)s [%(levelname)8s] %(name)s (%(filename)s:%(lineno)s): %(message)s

# =============================================================================
# API TESTING CONFIGURATION
# =============================================================================

# Base URL for API endpoints
API_BASE_URL=https://api.example.com

# API request timeout (milliseconds)
API_TIMEOUT=10000

# API authentication type (none, basic, bearer, api_key)
API_AUTH_TYPE=none

# API authentication credentials
API_USERNAME=
API_PASSWORD=
API_BEARER_TOKEN=
API_KEY=

# API headers (JSON format)
API_HEADERS={"Content-Type": "application/json", "Accept": "application/json"}

# =============================================================================
# DATABASE TESTING CONFIGURATION
# =============================================================================

# Database type (postgresql, mysql, mongodb, redis, sqlite)
DB_TYPE=postgresql

# Database connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=testuser
DB_PASSWORD=testpass

# Database connection string (alternative to individual settings)
DB_CONNECTION_STRING=

# Database connection timeout (seconds)
DB_TIMEOUT=30

# Database connection pool size
DB_POOL_SIZE=10

# =============================================================================
# MOBILE TESTING CONFIGURATION
# =============================================================================

# Enable mobile testing (true/false)
MOBILE_TESTING=false

# Appium server URL
APPIUM_URL=http://localhost:4723/wd/hub

# Mobile platform (Android, iOS)
MOBILE_PLATFORM=Android

# Mobile device name
MOBILE_DEVICE_NAME=emulator-5554

# Mobile platform version
MOBILE_PLATFORM_VERSION=11.0

# Mobile app path (for native app testing)
MOBILE_APP_PATH=

# Mobile browser name (Chrome, Safari)
MOBILE_BROWSER_NAME=Chrome

# Mobile device orientation (portrait, landscape)
MOBILE_ORIENTATION=portrait

# =============================================================================
# CLOUD INTEGRATION CONFIGURATION
# =============================================================================

# Cloud provider (aws, azure, gcp, browserstack, saucelabs)
CLOUD_PROVIDER=

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEVICE_FARM_PROJECT=

# Azure Configuration
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=

# GCP Configuration
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=

# BrowserStack Configuration
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_BUILD=
BROWSERSTACK_PROJECT=

# Sauce Labs Configuration
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
SAUCE_BUILD=
SAUCE_PROJECT=

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================

# Enable notifications (true/false)
NOTIFICATIONS_ENABLED=true

# Slack webhook URL
SLACK_WEBHOOK_URL=

# Microsoft Teams webhook URL
TEAMS_WEBHOOK_URL=

# Email configuration
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# =============================================================================
# PERFORMANCE MONITORING CONFIGURATION
# =============================================================================

# Page load time threshold (milliseconds)
PERFORMANCE_PAGE_LOAD_THRESHOLD=3000

# API response time threshold (milliseconds)
PERFORMANCE_API_RESPONSE_THRESHOLD=1000

# Database query time threshold (milliseconds)
PERFORMANCE_DB_QUERY_THRESHOLD=500

# Memory usage threshold (MB)
PERFORMANCE_MEMORY_THRESHOLD=512

# CPU usage threshold (percentage)
PERFORMANCE_CPU_THRESHOLD=80

# Network latency threshold (milliseconds)
PERFORMANCE_NETWORK_THRESHOLD=100

# =============================================================================
# SECURITY TESTING CONFIGURATION
# =============================================================================

# Enable security scanning (true/false)
SECURITY_ENABLED=false

# Security scan types (comma-separated: xss, sql_injection, csrf, etc.)
SECURITY_SCAN_TYPES=xss,sql_injection

# Security vulnerability threshold (number of issues to fail test)
SECURITY_VULNERABILITY_THRESHOLD=5

# Security scan timeout (seconds)
SECURITY_SCAN_TIMEOUT=30

# =============================================================================
# VISUAL REGRESSION CONFIGURATION
# =============================================================================

# Enable visual regression testing (true/false)
VISUAL_REGRESSION_ENABLED=true

# Visual diff threshold (0.0 to 1.0)
VISUAL_DIFF_THRESHOLD=0.01

# Baseline screenshots directory
VISUAL_BASELINE_DIR=reports/visual-baseline

# Current screenshots directory
VISUAL_CURRENT_DIR=reports/visual-current

# Diff screenshots directory
VISUAL_DIFF_DIR=reports/visual-diff

# =============================================================================
# ACCESSIBILITY TESTING CONFIGURATION
# =============================================================================

# Enable accessibility testing (true/false)
ACCESSIBILITY_ENABLED=true

# Accessibility standards (wcag2a, wcag2aa, wcag21a, wcag21aa)
ACCESSIBILITY_STANDARDS=wcag2aa

# Accessibility impact levels to check (minor, moderate, serious, critical)
ACCESSIBILITY_IMPACT_LEVELS=moderate,serious,critical

# Accessibility rules to ignore (comma-separated)
ACCESSIBILITY_IGNORE_RULES=

# =============================================================================
# CI/CD INTEGRATION CONFIGURATION
# =============================================================================

# CI/CD platform (github, gitlab, jenkins, azure, circleci)
CI_PLATFORM=

# CI build number
CI_BUILD_NUMBER=

# CI build URL
CI_BUILD_URL=

# CI commit SHA
CI_COMMIT_SHA=

# CI branch name
CI_BRANCH_NAME=

# CI pull request number
CI_PR_NUMBER=

# =============================================================================
# MONITORING AND ANALYTICS CONFIGURATION
# =============================================================================

# Enable monitoring (true/false)
MONITORING_ENABLED=true

# Monitoring endpoint URL
MONITORING_ENDPOINT=

# Monitoring API key
MONITORING_API_KEY=

# Metrics collection interval (seconds)
METRICS_INTERVAL=60

# Enable analytics (true/false)
ANALYTICS_ENABLED=false

# Analytics tracking ID
ANALYTICS_TRACKING_ID=

# =============================================================================
# DATA MANAGEMENT CONFIGURATION
# =============================================================================

# Test data directory
TEST_DATA_DIR=data

# Test data format (json, csv, excel, yaml)
TEST_DATA_FORMAT=json

# Enable data generation (true/false)
DATA_GENERATION_ENABLED=true

# Data generation locale
DATA_LOCALE=en_US

# Enable data cleanup after tests (true/false)
DATA_CLEANUP_ENABLED=true

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Custom test markers (comma-separated)
CUSTOM_MARKERS=

# Custom pytest options
CUSTOM_PYTEST_OPTIONS=

# Custom browser capabilities (JSON format)
CUSTOM_CAPABILITIES={}

# Custom test execution hooks
PRE_TEST_HOOK=
POST_TEST_HOOK=

# Custom reporting hooks
REPORTING_HOOK=

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode (true/false)
DEBUG_MODE=false

# Enable verbose logging (true/false)
VERBOSE_LOGGING=false

# Enable development tools (true/false)
DEV_TOOLS=false

# Development server URL
DEV_SERVER_URL=

# Hot reload enabled (true/false)
HOT_RELOAD=false
