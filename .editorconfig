# EditorConfig Configuration
# =========================
#
# This file defines coding styles for different file types.
# Most editors support EditorConfig: https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4
max_line_length = 88

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,css,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = 80

[*.{sh,bash}]
end_of_line = lf

[Makefile]
indent_style = tab

[*.{svg,png,jpg,jpeg,gif,ico}]
insert_final_newline = false
trim_trailing_whitespace = false

# Ignore files
[*.min.*]
indent_style = ignore
trim_trailing_whitespace = ignore

[{package.json,.travis.yml}]
indent_size = 2